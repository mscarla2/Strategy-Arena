# ── Schwab API ────────────────────────────────────────────────────────────────
# 1. Go to https://developer.schwab.com → create an app
# 2. Set Callback URL to:  https://127.0.0.1
# 3. Copy your client ID and secret below

SCHWAB_CLIENT_ID=your_schwab_client_id_here
SCHWAB_CLIENT_SECRET=your_schwab_client_secret_here

# 4. Run first auth (opens browser, auto-captures the OAuth code):
#      python -m side_by_side_backtest.schwab_broker --auth
#
# 5. Get your account hash:
#      python -m side_by_side_backtest.schwab_broker --get-account-hash

SCHWAB_ACCOUNT_HASH=your_schwab_account_hash_here
